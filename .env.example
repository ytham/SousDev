# 🍳 SousDev Environment Variables
# Copy this file to .env and fill in your values.
# The .env file is automatically loaded on startup.

# ---- Usually NOT required ----
# The default claude-loop technique uses the Claude CLI, which has its
# own authentication (run `claude` once to set it up via OAuth).
# You do NOT need an API key for normal operation.

# Anthropic API key — only needed for harness-native techniques
# (react, reflexion, plan-and-solve, etc.) which call the API directly.
# ANTHROPIC_API_KEY=sk-ant-...

# ---- Optional ----

# OpenAI API key (only needed if provider = "openai" in config.toml)
# OPENAI_API_KEY=sk-...

# Linear API key (only needed for the linear_issues workflow trigger)
# LINEAR_API_KEY=lin_api_...

# GitHub token (usually not needed — the `gh` CLI handles auth via
# `gh auth login`.  Only set this if you need to override.)
# GITHUB_TOKEN=ghp_...
